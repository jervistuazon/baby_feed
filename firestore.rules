rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasVerifiedEmail() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email_verified == true;
    }

    function familyDoc(familyId) {
      return /databases/$(database)/documents/families/$(familyId);
    }

    function memberDoc(familyId, uid) {
      return /databases/$(database)/documents/families/$(familyId)/members/$(uid);
    }

    function inviteDoc(familyId) {
      return /databases/$(database)/documents/families/$(familyId)/invites/$(request.auth.token.email);
    }

    function hasFamilyInvite(familyId) {
      return hasVerifiedEmail() && exists(inviteDoc(familyId));
    }

    function invitedRole(familyId) {
      return get(inviteDoc(familyId)).data.role;
    }

    function isFamilyMember(familyId) {
      return signedIn() && exists(memberDoc(familyId, request.auth.uid));
    }

    function isFamilyOwner(familyId) {
      return signedIn() && get(familyDoc(familyId)).data.ownerUid == request.auth.uid;
    }

    function validDayId(dayId) {
      return dayId.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function validDay(dayId) {
      return request.resource.data.keys().hasOnly([
        'dateKey',
        'updatedAt',
        'updatedBy'
      ])
      && request.resource.data.dateKey == dayId
      && request.resource.data.updatedBy == request.auth.uid;
    }

    function validEntry(entryId) {
      return request.resource.data.keys().hasOnly([
        'id',
        'timeMinutes',
        'milk',
        'milkAmountMl',
        'pee',
        'poop',
        'notes',
        'createdAt',
        'updatedAt',
        'updatedBy'
      ])
      && request.resource.data.id == entryId
      && request.resource.data.timeMinutes is int
      && request.resource.data.timeMinutes >= 0
      && request.resource.data.timeMinutes < 1440
      && request.resource.data.milk is bool
      && (
        request.resource.data.milkAmountMl == null
        || (
          request.resource.data.milkAmountMl is int
          && request.resource.data.milkAmountMl > 0
          && request.resource.data.milkAmountMl <= 999
        )
      )
      && request.resource.data.pee is bool
      && request.resource.data.poop is bool
      && request.resource.data.notes is string
      && request.resource.data.notes.size() <= 80
      && request.resource.data.updatedBy == request.auth.uid;
    }

    function validMember(familyId, memberUid) {
      return request.resource.data.keys().hasOnly(['uid', 'email', 'displayName', 'role', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && memberUid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 120
        && request.resource.data.role in ['owner', 'caregiver']
        && request.resource.data.role == invitedRole(familyId);
    }

    match /families/{familyId} {
      allow create: if hasFamilyInvite(familyId)
        && invitedRole(familyId) == 'owner'
        && request.resource.data.keys().hasOnly(['ownerUid', 'createdAt', 'updatedAt'])
        && request.resource.data.ownerUid == request.auth.uid;
      allow read: if isFamilyMember(familyId) || hasFamilyInvite(familyId);
      allow update: if isFamilyOwner(familyId)
        && request.resource.data.keys().hasOnly(['ownerUid', 'createdAt', 'updatedAt'])
        && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if isFamilyOwner(familyId);

      match /members/{memberUid} {
        allow read: if isFamilyMember(familyId) || (hasFamilyInvite(familyId) && memberUid == request.auth.uid);
        allow create: if hasFamilyInvite(familyId) && validMember(familyId, memberUid);
        allow update, delete: if isFamilyOwner(familyId);
      }

      match /invites/{inviteEmail} {
        allow read, write: if isFamilyOwner(familyId);
      }

      match /days/{dayId} {
        allow read: if isFamilyMember(familyId) && validDayId(dayId);
        allow create, update: if isFamilyMember(familyId) && validDayId(dayId) && validDay(dayId);
        allow delete: if isFamilyMember(familyId) && validDayId(dayId);

        match /entries/{entryId} {
          allow read: if isFamilyMember(familyId) && validDayId(dayId);
          allow create, update: if isFamilyMember(familyId) && validDayId(dayId) && validEntry(entryId);
          allow delete: if isFamilyMember(familyId) && validDayId(dayId);
        }
      }
    }
  }
}
